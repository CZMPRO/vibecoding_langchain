{
  "permissions": {
    "allow": [
      "Bash(git ls-tree *)",
      "Bash(git log *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/claude-pre-bash-commit-gate.js",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/claude-post-bash-push-clear.js",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
